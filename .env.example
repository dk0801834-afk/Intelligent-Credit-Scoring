# Copy this file to ".env" and fill in your MySQL credentials.
# If MySQL is unreachable, the app automatically falls back to SQLite.

DB_BACKEND=auto          # auto | mysql | sqlite
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=Dheeraj@123
MYSQL_DATABASE=credit_scoring

# Number of new applications that triggers a background retrain
RETRAIN_THRESHOLD=10
